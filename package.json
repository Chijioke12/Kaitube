{
  "name": "kaios-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "icons": "tsx scripts/generate-icons.js",
    "build": "vite build && node scripts/csp-fix.js",
    "package": "npm run icons && npm run build && tsx scripts/package-omnisd.js",
