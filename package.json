    "start": "node server.ts",
    "clean": "rm -rf dist build",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/express": "^5.0.6",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-legacy": "^6.1.1",
    "adm-zip": "^0.5.16",
    "autoprefixer": "^10.4.27",
    "eruda": "^3.4.3",
    "postcss": "^8.5.8",
    "terser": "^5.46.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "browserslist": [
    "Firefox >= 48"
  ]
